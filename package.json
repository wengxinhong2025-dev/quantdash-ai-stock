    "sync:kline:py": "node scripts/syncKlineLibraryPy.js",
    "sync:cycle": "node scripts/syncSentimentCycleSnapshotsPy.js",
    "sync:cycle:py": "node scripts/syncSentimentCycleSnapshotsPy.js",
    "sync:stocks": "node scripts/syncStockSnapshotsPy.js",
    "sync:sectors": "node scripts/syncSectorSnapshotsPy.js",
    "sync:stocks:py": "node scripts/syncStockSnapshotsPy.js",
    "sync:sectors:py": "node scripts/syncSectorSnapshotsPy.js",
    "sync:offline:py": "node scripts/syncPythonOfflineData.js",
